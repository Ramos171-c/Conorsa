<UserControl x:Class="EnterpriseBillingSystem.Wpf.Views.MobileOrders.MobileOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:EnterpriseBillingSystem.Wpf.Views.MobileOrders"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1050"
             Loaded="UserControl_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Seguimiento de Pedidos Móviles" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock Text="Monitoree los pedidos de venta tomados por sus vendedores y cajeros en terreno." Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding OpenRecentOrdersReportCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Resumen de Pedidos para Compra" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Actualizar" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,16" Padding="16" materialDesign:ElevationAssist.Elevation="Dp1">
            <StackPanel Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding Statuses}" 
                          SelectedItem="{Binding SelectedStatus}" 
                          materialDesign:HintAssist.Hint="Filtrar por Estado"
                          Width="220" Margin="0,0,16,0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <ComboBox ItemsSource="{Binding Routes}" 
                          SelectedItem="{Binding SelectedRoute}" 
                          DisplayMemberPath="Name"
                          materialDesign:HintAssist.Hint="Filtrar por Ruta"
                          Width="220"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />
            </StackPanel>
        </materialDesign:Card>

        <!-- Main Tab Control -->
        <TabControl Grid.Row="2" Style="{StaticResource MaterialDesignTabControl}">
            
            <!-- Tab 1: Individual Orders -->
            <TabItem Header="Pedidos Individuales">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Data Grid Card -->
                    <materialDesign:Card Grid.Row="0" materialDesign:ElevationAssist.Elevation="Dp1">
                        <Grid>
                            <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}" IsIndeterminate="True" 
                                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" 
                                         VerticalAlignment="Top" Height="4" Panel.ZIndex="10" />

                            <!-- Main DataGrid -->
                            <DataGrid ItemsSource="{Binding Orders}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                      Visibility="{Binding ConnectionFailed, Converter={StaticResource InverseBoolToVis}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nro. Pedido" Binding="{Binding OrderNumber}" Width="120" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" FontWeight="Bold" />
                                    <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                                    <DataGridTextColumn Header="Fecha Pedido" Binding="{Binding OrderDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                                    <DataGridTextColumn Header="Subtotal" Binding="{Binding SubTotal, StringFormat={}{0:C2}}" Width="110" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                                    <DataGridTextColumn Header="Descuento" Binding="{Binding DiscountAmount, StringFormat={}{0:C2}}" Width="100" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                                    <DataGridTextColumn Header="Impuestos" Binding="{Binding TaxAmount, StringFormat={}{0:C2}}" Width="100" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="120" ElementStyle="{StaticResource RightAlignedColumnStyle}" FontWeight="Bold" />
                                    
                                    <!-- Status Badge -->
                                    <DataGridTemplateColumn Header="Estado" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Solicitud">
                                                                    <Setter Property="Background" Value="#FFF3E0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Recibido">
                                                                    <Setter Property="Background" Value="#E8F5E9" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Anulado">
                                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="EnProceso">
                                                                    <Setter Property="Background" Value="#E3F2FD" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="EnCamino">
                                                                    <Setter Property="Background" Value="#E0F7FA" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completado">
                                                                    <Setter Property="Background" Value="#E8F5E9" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="SolicitudAnulacion">
                                                                    <Setter Property="Background" Value="#FFEBEE" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontWeight="Bold" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Solicitud">
                                                                        <Setter Property="Text" Value="SOLICITUD" />
                                                                        <Setter Property="Foreground" Value="#E65100" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Recibido">
                                                                        <Setter Property="Text" Value="RECIBIDO" />
                                                                        <Setter Property="Foreground" Value="#2E7D32" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Anulado">
                                                                        <Setter Property="Text" Value="ANULADO" />
                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="EnProceso">
                                                                        <Setter Property="Text" Value="EN PROCESO" />
                                                                        <Setter Property="Foreground" Value="#1565C0" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="EnCamino">
                                                                        <Setter Property="Text" Value="EN CAMINO" />
                                                                        <Setter Property="Foreground" Value="#00838F" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Completado">
                                                                        <Setter Property="Text" Value="COMPLETADO" />
                                                                        <Setter Property="Foreground" Value="#2E7D32" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="SolicitudAnulacion">
                                                                        <Setter Property="Text" Value="SOLICITUD ANULACIÓN" />
                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Actions Column -->
                                    <DataGridTemplateColumn Header="Acciones" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <!-- View Details Button -->
                                                    <Button Command="{Binding DataContext.ViewOrderDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                            CommandParameter="{Binding}" 
                                                            Style="{StaticResource MaterialDesignIconButton}" 
                                                            ToolTip="Ver Detalle" Width="30" Height="30" Padding="0" Margin="0,0,4,0">
                                                        <materialDesign:PackIcon Kind="Eye" Width="16" Height="16" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                                    </Button>
                                                    <!-- Confirm Button (Only visible if Recibido) -->
                                                     <Button Command="{Binding DataContext.ConfirmOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                             CommandParameter="{Binding}" 
                                                             ToolTip="Procesar Pedido" Width="30" Height="30" Padding="0" Margin="0,0,4,0">
                                                          <Button.Style>
                                                              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                                  <Setter Property="Visibility" Value="Collapsed" />
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding Status}" Value="Recibido">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </Button.Style>
                                                          <materialDesign:PackIcon Kind="Check" Width="16" Height="16" Foreground="#2E7D32" />
                                                      </Button>

                                                     <!-- Ship Button (Only visible if EnProceso) -->
                                                     <Button Command="{Binding DataContext.ShipOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                             CommandParameter="{Binding}" 
                                                             ToolTip="Confirmar Envío (En Camino)" Width="30" Height="30" Padding="0" Margin="0,0,4,0">
                                                          <Button.Style>
                                                              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                                  <Setter Property="Visibility" Value="Collapsed" />
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding Status}" Value="EnProceso">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </Button.Style>
                                                          <materialDesign:PackIcon Kind="TruckDelivery" Width="16" Height="16" Foreground="#1565C0" />
                                                      </Button>

                                                     <!-- Deliver Button (Only visible if EnCamino) -->
                                                     <Button Command="{Binding DataContext.DeliverOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                             CommandParameter="{Binding}" 
                                                             ToolTip="Confirmar Entrega (Completado)" Width="30" Height="30" Padding="0" Margin="0,0,4,0">
                                                          <Button.Style>
                                                              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                                  <Setter Property="Visibility" Value="Collapsed" />
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding Status}" Value="EnCamino">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </Button.Style>
                                                          <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Foreground="#2E7D32" />
                                                      </Button>
 
                                                      <!-- Cancel Button (Visible if Recibido or EnProceso) -->
                                                      <Button Command="{Binding DataContext.CancelOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                              CommandParameter="{Binding}" 
                                                              ToolTip="Anular Pedido" Width="30" Height="30" Padding="0" Margin="0,0,4,0">
                                                          <Button.Style>
                                                              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                                  <Setter Property="Visibility" Value="Collapsed" />
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding Status}" Value="Recibido">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                      <DataTrigger Binding="{Binding Status}" Value="EnProceso">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </Button.Style>
                                                          <materialDesign:PackIcon Kind="Cancel" Width="16" Height="16" Foreground="#C62828" />
                                                      </Button>

                                                      <!-- Approve Cancellation Button (Only visible if SolicitudAnulacion) -->
                                                      <Button Command="{Binding DataContext.ApproveCancellationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                              CommandParameter="{Binding}" 
                                                              ToolTip="Aprobar Solicitud de Anulación" Width="30" Height="30" Padding="0" Margin="0,0,4,0">
                                                          <Button.Style>
                                                              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                                  <Setter Property="Visibility" Value="Collapsed" />
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding Status}" Value="SolicitudAnulacion">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </Button.Style>
                                                          <materialDesign:PackIcon Kind="Check" Width="16" Height="16" Foreground="#2E7D32" />
                                                      </Button>

                                                      <!-- Reject Cancellation Button (Only visible if SolicitudAnulacion) -->
                                                      <Button Command="{Binding DataContext.RejectCancellationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                              CommandParameter="{Binding}" 
                                                              ToolTip="Rechazar Solicitud de Anulación" Width="30" Height="30" Padding="0">
                                                          <Button.Style>
                                                              <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                                  <Setter Property="Visibility" Value="Collapsed" />
                                                                  <Style.Triggers>
                                                                      <DataTrigger Binding="{Binding Status}" Value="SolicitudAnulacion">
                                                                          <Setter Property="Visibility" Value="Visible" />
                                                                      </DataTrigger>
                                                                  </Style.Triggers>
                                                              </Style>
                                                          </Button.Style>
                                                          <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="#C62828" />
                                                      </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Connection Error View -->
                            <StackPanel Visibility="{Binding ConnectionFailed, Converter={StaticResource BoolToVis}}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                <materialDesign:PackIcon Kind="WifiOff" Width="64" Height="64" Foreground="#C62828" HorizontalAlignment="Center" Margin="0,0,0,16" />
                                <TextBlock Text="Error de Conexión" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                                <TextBlock Text="No se pudo establecer conexión con el servidor de pedidos." Style="{StaticResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center" Opacity="0.7" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource MaterialDesignBody2TextBlock}" HorizontalAlignment="Center" Opacity="0.5" FontStyle="Italic" Margin="0,0,0,24" TextWrapping="Wrap" MaxWidth="400" />
                                <Button Command="{Binding LoadOrdersCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="160" Background="#C62828" BorderBrush="#C62828">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Reintentar" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Pagination -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <TextBlock Text="Página: " VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding PageNumber}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0" />

                        <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Margin="0,0,4,0">
                            <materialDesign:PackIcon Kind="ChevronLeft" />
                        </Button>

                        <Button Command="{Binding NextPageCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32">
                            <materialDesign:PackIcon Kind="ChevronRight" />
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 2: Consolidated Delivery Load -->
            <TabItem Header="Consolidado de Carga">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Consolidated Grid Card -->
                    <materialDesign:Card Grid.Row="0" materialDesign:ElevationAssist.Elevation="Dp1">
                        <Grid>
                            <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}" IsIndeterminate="True" 
                                         Visibility="{Binding IsConsolidationLoading, Converter={StaticResource BoolToVis}}" 
                                         VerticalAlignment="Top" Height="4" Panel.ZIndex="10" />

                            <!-- Consolidated DataGrid -->
                            <DataGrid ItemsSource="{Binding ConsolidatedProducts}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                                      Visibility="{Binding ConnectionFailed, Converter={StaticResource InverseBoolToVis}}">
                                <DataGrid.Columns>
                                    <!-- Interactive Checklist Checkbox -->
                                    <DataGridTemplateColumn Header="Verificado" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsVerified, UpdateSourceTrigger=PropertyChanged}" 
                                                          HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Código" Binding="{Binding ProductCode}" Width="150" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" FontWeight="Bold" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Producto" Binding="{Binding ProductName}" Width="*" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn Header="U.M." Binding="{Binding UnitOfMeasure}" Width="100" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" IsReadOnly="True" />
                                    
                                    <DataGridTextColumn Header="Cant. Solicitada" Binding="{Binding TotalQuantity, StringFormat={}{0:N2}}" Width="120" ElementStyle="{StaticResource RightAlignedColumnStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Stock Deducido" Binding="{Binding DeductedFromInventory, StringFormat={}{0:N2}}" Width="120" ElementStyle="{StaticResource RightAlignedColumnStyle}" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Neto a Pedir" Binding="{Binding NetQuantityToOrder, StringFormat={}{0:N2}}" Width="120" ElementStyle="{StaticResource RightAlignedColumnStyle}" IsReadOnly="True" FontWeight="Bold" />
                                    
                                    <!-- Editable Loaded Quantity -->
                                    <DataGridTemplateColumn Header="Cant. Real Cargada" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding QuantityLoaded, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}" 
                                                         Style="{StaticResource MaterialDesignTextBox}"
                                                         HorizontalAlignment="Right" TextAlignment="Right" Width="100" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Total Neto" Binding="{Binding TotalNetAmount, StringFormat={}{0:C2}}" Width="130" ElementStyle="{StaticResource RightAlignedColumnStyle}" IsReadOnly="True" FontWeight="Bold" />
                                    <DataGridTextColumn Header="Observaciones" Binding="{Binding Observation}" Width="180" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Connection Error View for Consolidation -->
                            <StackPanel Visibility="{Binding ConnectionFailed, Converter={StaticResource BoolToVis}}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                <materialDesign:PackIcon Kind="WifiOff" Width="64" Height="64" Foreground="#C62828" HorizontalAlignment="Center" Margin="0,0,0,16" />
                                <TextBlock Text="Error de Conexión" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                                <TextBlock Text="No se pudo establecer conexión con el servidor de pedidos." Style="{StaticResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center" Opacity="0.7" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource MaterialDesignBody2TextBlock}" HorizontalAlignment="Center" Opacity="0.5" FontStyle="Italic" Margin="0,0,0,24" TextWrapping="Wrap" MaxWidth="400" />
                                <Button Command="{Binding LoadOrdersCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="160" Background="#C62828" BorderBrush="#C62828">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Reintentar" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Consolidation Action Buttons -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Help / Hint Text -->
                        <TextBlock Grid.Column="0" Text="* Chequee físicamente cada producto cargado en el vehículo antes de despachar." 
                                   Style="{StaticResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center" Opacity="0.6" FontStyle="Italic" />

                        <!-- Actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding VerifyAllConsolidatedCommand}" 
                                    Style="{StaticResource MaterialDesignFlatButton}" 
                                    Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckAll" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Marcar todo como Verificado" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding DispatchConsolidatedCommand}" 
                                    IsEnabled="{Binding CanDispatchConsolidated}"
                                    Style="{StaticResource MaterialDesignRaisedButton}" 
                                    Background="#2E7D32" BorderBrush="#2E7D32">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="TruckDelivery" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Convalidar y Despachar Pedidos" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
