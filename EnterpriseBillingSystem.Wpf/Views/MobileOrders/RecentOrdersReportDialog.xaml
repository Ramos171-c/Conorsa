<Window x:Class="EnterpriseBillingSystem.Wpf.Views.MobileOrders.RecentOrdersReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Consolidación de Pedidos para Compra (Bodega Única)" Height="720" Width="1050"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Encabezado -->
            <RowDefinition Height="Auto" /> <!-- Tarjetas KPI Resumen -->
            <RowDefinition Height="*" />    <!-- Tabla de Productos -->
            <RowDefinition Height="Auto" /> <!-- Observaciones Generales -->
            <RowDefinition Height="Auto" /> <!-- Footer Acciones -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <materialDesign:PackIcon Kind="ClipboardTextOutline" Width="28" Height="28" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Consolidación de Pedidos para Compra (Bodega Única)" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Descuento automático de existencias de inventario para generar el neto real a pedir a proveedor." Opacity="0.7" FontSize="12"/>
            </StackPanel>
        </Grid>

        <!-- Summary Info Card (5 Financial KPIs) -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,16" Padding="12,14" materialDesign:ElevationAssist.Elevation="Dp1" Background="#F8FAFC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Consolidado Financiero de Compras y Ventas" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="Deducción exacta de existencias y margen proyectado" Opacity="0.7" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- KPI 1: Deducido de Inventario (Existencia) -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="CUBIERTO EN BODEGA" FontSize="10" Foreground="#166534" FontWeight="Bold" HorizontalAlignment="Right" />
                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Right">
                        <Run Text="{Binding TotalDeducted, StringFormat={}{0:N2}}" /><Run Text=" pzas" />
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#15803D" HorizontalAlignment="Right">
                        <Run Text="Val. Compra: " /><Run Text="{Binding TotalInventoryDeductedPurchaseCost, StringFormat={}{0:C2}}" />
                    </TextBlock>
                </StackPanel>

                <!-- KPI 2: Neto a Comprar al Proveedor -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL COMPRA (NETO)" FontSize="10" Foreground="#B45309" FontWeight="Bold" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding TotalEstimatedCost, StringFormat={}{0:C2}}" FontSize="16" FontWeight="Bold" Foreground="#B45309" HorizontalAlignment="Right" />
                    <TextBlock FontSize="10" Foreground="#B45309" HorizontalAlignment="Right">
                        <Run Text="{Binding TotalNetToOrder, StringFormat={}{0:N2}}" /><Run Text=" pzas a pedir" />
                    </TextBlock>
                </StackPanel>

                <!-- KPI 3: Venta Total Neta Estimada -->
                <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="TOTAL VENTA (CLIENTES)" FontSize="10" Foreground="#1E40AF" FontWeight="Bold" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding TotalEstimatedSales, StringFormat={}{0:C2}}" FontSize="16" FontWeight="Bold" Foreground="#1E40AF" HorizontalAlignment="Right" />
                </StackPanel>

                <!-- KPI 4: Diferencia en Dinero -->
                <StackPanel Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="DIFERENCIA GANANCIA" FontSize="10" Foreground="#15803D" FontWeight="Bold" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding TotalProfitMargin, StringFormat={}{0:C2}}" FontSize="16" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Right" />
                </StackPanel>

                <!-- KPI 5: Margen % -->
                <StackPanel Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="MARGEN BRUTO" FontSize="10" Foreground="#15803D" FontWeight="Bold" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding ProfitMarginPercentage, StringFormat={}{0:N1}%}" FontSize="16" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Content Card (Grid) -->
        <materialDesign:Card Grid.Row="2" Margin="0,0,0,12" materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}" IsIndeterminate="True" 
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" 
                             VerticalAlignment="Top" Height="4" Panel.ZIndex="10" />

                <DataGrid ItemsSource="{Binding ConsolidatedProducts}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding ProductCode}" Width="95" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" FontWeight="Bold" />
                        <DataGridTextColumn Header="Producto" Binding="{Binding ProductName}" Width="*" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                        <DataGridTextColumn Header="U.M." Binding="{Binding UnitOfMeasure}" Width="65" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                        <DataGridTextColumn Header="Cant. Pedida" Binding="{Binding TotalQuantity, StringFormat={}{0:N2}}" Width="95" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                        <DataGridTextColumn Header="Stock Deducido" Binding="{Binding DeductedFromInventory, StringFormat={}{0:N2}}" Width="105" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                        <DataGridTextColumn Header="Neto A Pedir" Binding="{Binding NetQuantityToOrder, StringFormat={}{0:N2}}" Width="100" ElementStyle="{StaticResource RightAlignedColumnStyle}" FontWeight="Bold" />
                        <DataGridTextColumn Header="Costo Unit." Binding="{Binding UnitCost, StringFormat={}{0:C2}}" Width="90" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                        <DataGridTextColumn Header="Total Compra" Binding="{Binding TotalPurchaseCost, StringFormat={}{0:C2}}" Width="110" ElementStyle="{StaticResource RightAlignedColumnStyle}" FontWeight="Bold" Foreground="#B45309" />
                        <DataGridTextColumn Header="Venta Unit." Binding="{Binding UnitPrice, StringFormat={}{0:C2}}" Width="90" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                        <DataGridTextColumn Header="Total Venta" Binding="{Binding NetSalesAmount, StringFormat={}{0:C2}}" Width="110" ElementStyle="{StaticResource RightAlignedColumnStyle}" FontWeight="Bold" Foreground="#1E40AF" />
                        <DataGridTextColumn Header="Diferencia ($)" Binding="{Binding ProfitMarginAmount, StringFormat={}{0:C2}}" Width="115" ElementStyle="{StaticResource RightAlignedColumnStyle}" FontWeight="Bold" Foreground="#15803D" />
                        <DataGridTextColumn Header="Observaciones" Binding="{Binding Observation}" Width="160" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
                
                <!-- Empty State Message -->
                <TextBlock Text="No se encontraron pedidos móviles en estado Recibido." 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Style="{StaticResource MaterialDesignBody1TextBlock}" Opacity="0.5"
                           Visibility="{Binding ShowEmptyMessage, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </materialDesign:Card>

        <!-- Observaciones Generales -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Observaciones Generales del Consolidado (se incluirán en el Excel)" 
                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}" 
                       FontWeight="Bold" Margin="0,0,0,4" />
            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding GeneralObservations, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="True" AcceptsReturn="True" Height="50" FontSize="13" VerticalContentAlignment="Top" />
        </StackPanel>

        <!-- Footer Actions -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Click="ExportExcel_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Background="#166534" BorderBrush="#166534"
                    IsEnabled="{Binding HasData}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Exportar a Excel (.xlsx)" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Click="ConfirmResumen_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    IsEnabled="{Binding HasData}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Confirmar Resumen (Pasar a En Proceso)" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            
            <Button Grid.Column="4" Style="{StaticResource MaterialDesignFlatButton}" 
                    Click="Close_Click" Content="Cerrar" />
        </Grid>
    </Grid>
</Window>
