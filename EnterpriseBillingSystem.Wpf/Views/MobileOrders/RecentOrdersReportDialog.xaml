<Window x:Class="EnterpriseBillingSystem.Wpf.Views.MobileOrders.RecentOrdersReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Consolidación de Pedidos para Compra" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F1F5F9"
        Foreground="#0F172A"
        FontSize="13"
        FontFamily="Segoe UI">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1. Título de la Ventana -->
        <TextBlock Grid.Row="0" Text="Consolidación de Pedidos para Compra (Bodega Única)" 
                   FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12" />

        <!-- 2. Resumen Financiero Sencillo -->
        <Border Grid.Row="1" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <UniformGrid Columns="4">
                <StackPanel Margin="8,0">
                    <TextBlock Text="CUBIERTO EN BODEGA" FontSize="11" Foreground="#475569" FontWeight="Bold" />
                    <TextBlock Text="{Binding TotalDeductedDisplay}" FontSize="15" FontWeight="Bold" Foreground="#16A34A" />
                </StackPanel>
                <StackPanel Margin="8,0">
                    <TextBlock Text="TOTAL COMPRA (NETO)" FontSize="11" Foreground="#475569" FontWeight="Bold" />
                    <TextBlock Text="{Binding TotalEstimatedCostDisplay}" FontSize="15" FontWeight="Bold" Foreground="#D97706" />
                </StackPanel>
                <StackPanel Margin="8,0">
                    <TextBlock Text="TOTAL VENTA (CLIENTES)" FontSize="11" Foreground="#475569" FontWeight="Bold" />
                    <TextBlock Text="{Binding TotalEstimatedSalesDisplay}" FontSize="15" FontWeight="Bold" Foreground="#2563EB" />
                </StackPanel>
                <StackPanel Margin="8,0">
                    <TextBlock Text="GANANCIA PROYECTADA" FontSize="11" Foreground="#475569" FontWeight="Bold" />
                    <TextBlock Text="{Binding TotalProfitMarginDisplay}" FontSize="15" FontWeight="Bold" Foreground="#16A34A" />
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- 3. Tabla Principal de Productos -->
        <Border Grid.Row="2" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12">
            <DataGrid ItemsSource="{Binding ConsolidatedProducts}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Código" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductCode}" VerticalAlignment="Center" Margin="6,4" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Producto" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductName}" VerticalAlignment="Center" Margin="6,4" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="U.M." Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UnitOfMeasure}" VerticalAlignment="Center" Margin="6,4" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Cant. Pedida" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalQuantity, StringFormat='{}{0:N2}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="En Bodega" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DeductedFromInventory, StringFormat='{}{0:N2}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" Foreground="#16A34A" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Neto A Pedir" Width="95">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NetQuantityToOrder, StringFormat='{}{0:N2}'}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" Foreground="#D97706" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Costo Unit." Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UnitCost, StringFormat='{}{0:C2}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Total Compra" Width="105">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalPurchaseCost, StringFormat='{}{0:C2}'}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" Foreground="#D97706" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Venta Unit." Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding UnitPrice, StringFormat='{}{0:C2}'}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Total Venta" Width="105">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NetSalesAmount, StringFormat='{}{0:C2}'}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" Foreground="#2563EB" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Ganancia ($)" Width="105">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProfitMarginAmount, StringFormat='{}{0:C2}'}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="6,4" Foreground="#16A34A" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 4. Observaciones Generales (Sencillo) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Observaciones Generales (se incluirán en el Excel)" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,4" />
            <TextBox x:Name="TxtGeneralObservations" Height="40" TextWrapping="True" AcceptsReturn="True" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" Padding="4" />
        </StackPanel>

        <!-- 5. Botones de Acción Directos -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="ExportExcel_Click" Content="Exportar a Excel (.xlsx)" 
                    Background="#166534" Foreground="White" BorderThickness="0" Padding="16,8" FontWeight="Bold" />

            <Button Grid.Column="2" Click="ConfirmResumen_Click" Content="Confirmar Resumen (Pasar a En Proceso)" 
                    Background="#2563EB" Foreground="White" BorderThickness="0" Padding="16,8" FontWeight="Bold" />

            <Button Grid.Column="4" Click="Close_Click" Content="Cerrar" 
                    Background="#E2E8F0" Foreground="#334155" BorderThickness="0" Padding="16,8" />
        </Grid>
    </Grid>
</Window>
