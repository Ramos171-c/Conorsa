<Window x:Class="EnterpriseBillingSystem.Wpf.Views.Suppliers.SupplierEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:EnterpriseBillingSystem.Wpf.Converters"
        mc:Ignorable="d"
        Title="Detalle del Proveedor" Height="600" Width="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:BooleanToVisibilityConverter x:Key="InverseBoolToVis" Inverse="True" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                            <Setter Property="Text" Value="Detalle del Proveedor" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsReadOnly}" Value="False">
                            <Setter Property="Text" Value="Nuevo Proveedor" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Form content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel Margin="4">
                <!-- Section 1: Commercial Data -->
                <TextBlock Text="Información Comercial" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,8,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <!-- Name -->
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Nombre del Proveedor *" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         IsReadOnly="{Binding IsReadOnly}"
                         Margin="0,0,0,12" />

                <!-- Legal Name -->
                <TextBox Text="{Binding LegalName, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Razón Social / Nombre Legal" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         IsReadOnly="{Binding IsReadOnly}"
                         Margin="0,0,0,12" />

                <!-- Category -->
                <ComboBox ItemsSource="{Binding Categories}" 
                          SelectedValue="{Binding SelectedCategoryId}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="Name"
                          materialDesign:HintAssist.Hint="Categoría del Proveedor *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                          Margin="0,0,0,12" />

                <!-- Section 2: Identification and Contacts -->
                <TextBlock Text="Identificación y Contactos" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,12,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" 
                              ItemsSource="{Binding IdentificationTypes}" 
                              SelectedItem="{Binding SelectedIdentificationType}"
                              materialDesign:HintAssist.Hint="Tipo Identificación"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                              Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" 
                             Text="{Binding IdentificationNumber, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Número Identificación *" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             IsReadOnly="{Binding IsReadOnly}"
                             Margin="6,0,0,0" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Teléfono" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             IsReadOnly="{Binding IsReadOnly}"
                             Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" 
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Correo Electrónico" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             IsReadOnly="{Binding IsReadOnly}"
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Contact Name -->
                <TextBox Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Persona de Contacto" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         IsReadOnly="{Binding IsReadOnly}"
                         Margin="0,0,0,12" />

                <!-- Address -->
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Dirección de la Empresa" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="75"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="{Binding IsReadOnly}"
                         Margin="0,0,0,12" />
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                    Content="Cerrar" 
                    Click="CancelButton_Click" 
                    Margin="0,0,8,0" 
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}" />

            <Button Command="{Binding SaveCommand}" 
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Width="120"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}"
                    Visibility="{Binding IsReadOnly, Converter={StaticResource InverseBoolToVis}}">
                <Grid>
                    <TextBlock Text="Guardar" Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVis}}" />
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Width="20" Height="20" Foreground="White" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Button>
        </StackPanel>
    </Grid>
</Window>
