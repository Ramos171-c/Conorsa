<UserControl x:Class="EnterpriseBillingSystem.Wpf.Views.Inventory.InventoryDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:EnterpriseBillingSystem.Wpf.Views.Inventory"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Section -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Dashboard de Inventario" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock Text="Monitoreo en tiempo real de existencias, valorización y alertas operativas de sucursal." Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Loading Indicator -->
            <ProgressBar Grid.Row="0" Style="{StaticResource MaterialDesignLinearProgressBar}" IsIndeterminate="True" 
                         Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                         VerticalAlignment="Bottom" Height="4" />

            <!-- KPI Cards Grid -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,24">
                <!-- Total Products Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Productos Totales" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding TotalProducts}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="PackageVariantClosed" Width="36" Height="36" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Active Products Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Activos" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding ActiveProducts}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" Foreground="Green" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="CheckCircleOutline" Width="36" Height="36" Foreground="Green" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Sold Out Products Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Agotados" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding SoldOutProducts}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" Foreground="Red" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="MinusCircleOutline" Width="36" Height="36" Foreground="Red" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Low Stock Alert Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2" Background="#FFF9C4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stock Bajo (Alertas)" Style="{StaticResource MaterialDesignBody2TextBlock}" Foreground="Black" Opacity="0.8" />
                            <TextBlock Text="{Binding LowStockProducts}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" Foreground="#F57F17" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="AlertCircleOutline" Width="36" Height="36" Foreground="#F57F17" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Inventory Value Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Valor de Inventario" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding InventoryValue, StringFormat={}{0:C}}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" Foreground="{DynamicResource SecondaryHueMidBrush}" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="CurrencyUsd" Width="36" Height="36" Foreground="{DynamicResource SecondaryHueMidBrush}" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Hidden Products Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ocultos de Catálogo" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding HiddenProducts}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="EyeOffOutline" Width="36" Height="36" Foreground="Gray" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Favorite POS Products Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Favoritos POS" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding FavoriteProducts}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" Foreground="Orange" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="StarOutline" Width="36" Height="36" Foreground="Orange" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Today's Adjustments Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ajustes de Hoy" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding TodayAdjustments}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="Tune" Width="36" Height="36" Foreground="Teal" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>

                <!-- Today's Transfers Card -->
                <materialDesign:Card Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Transferencias de Hoy" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
                            <TextBlock Text="{Binding TodayTransfers}" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Margin="0,8,0,0" />
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1" Kind="ArrowLeftRightBoldOutline" Width="36" Height="36" Foreground="Blue" VerticalAlignment="Center" />
                    </Grid>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Low Stock Grid Section -->
            <materialDesign:Card Grid.Row="2" Margin="8" Padding="16" materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="AlertDecagramOutline" Width="24" Height="24" Foreground="Red" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Productos con Stock Bajo" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>

                     <DataGrid Grid.Row="1" ItemsSource="{Binding LowStockItems}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="150" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                            <DataGridTextColumn Header="Producto" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}" />
                            <DataGridTextColumn Header="Existencia Actual" Binding="{Binding CurrentStock, StringFormat={}{0:N2}}" Width="150" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                            <DataGridTextColumn Header="Stock Mínimo" Binding="{Binding MinimumStock, StringFormat={}{0:N2}}" Width="150" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
