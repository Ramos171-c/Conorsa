<UserControl x:Class="EnterpriseBillingSystem.Wpf.Views.Inventory.InventoryTransfersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:EnterpriseBillingSystem.Wpf.Views.Inventory"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Transferencias entre Bodegas" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
            <TextBlock Text="Transfiera stock físico de productos entre las bodegas habilitadas para la sucursal." Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" />
        </StackPanel>

        <!-- Form Card -->
        <materialDesign:Card Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Left" Width="600" Padding="24" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ProgressBar Style="{StaticResource MaterialDesignLinearProgressBar}" IsIndeterminate="True" 
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             VerticalAlignment="Top" Height="4" Margin="0,-24,0,24" />

                <!-- Source Warehouse Selection -->
                <ComboBox Grid.Row="0" ItemsSource="{Binding Warehouses}" 
                          SelectedValue="{Binding SelectedSourceWarehouseId}" 
                          SelectedValuePath="Id" 
                          DisplayMemberPath="Name" 
                          materialDesign:HintAssist.Hint="Bodega Origen"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                          Margin="0,0,0,16" />

                <!-- Destination Warehouse Selection -->
                <ComboBox Grid.Row="1" ItemsSource="{Binding Warehouses}" 
                          SelectedValue="{Binding SelectedDestWarehouseId}" 
                          SelectedValuePath="Id" 
                          DisplayMemberPath="Name" 
                          materialDesign:HintAssist.Hint="Bodega Destino"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                          Margin="0,0,0,16" />

                <!-- Product Selection -->
                <ComboBox Grid.Row="2" ItemsSource="{Binding Products}" 
                          SelectedItem="{Binding SelectedProduct}" 
                          DisplayMemberPath="Name" 
                          materialDesign:HintAssist.Hint="Seleccionar Producto"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                          Margin="0,0,0,16" />

                <!-- Quantity -->
                <TextBox Grid.Row="3" Text="{Binding Quantity}" 
                         materialDesign:HintAssist.Hint="Cantidad a Transferir" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,0,0,16" />

                <!-- Notes / Reason -->
                <TextBox Grid.Row="4" Text="{Binding Notes}" 
                         materialDesign:HintAssist.Hint="Observaciones / Documento de Referencia" 
                         AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,0,0,24" />

                <!-- Action button -->
                <Button Grid.Row="5" Command="{Binding ExecuteTransferCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="48" materialDesign:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeftRight" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Procesar Transferencia de Mercadería" VerticalAlignment="Center" FontWeight="Bold" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
