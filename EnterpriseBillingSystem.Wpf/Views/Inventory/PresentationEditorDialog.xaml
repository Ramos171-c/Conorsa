<Window x:Class="EnterpriseBillingSystem.Wpf.Views.Inventory.PresentationEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="{Binding DialogTitle}" Height="540" Width="650"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16" />

        <!-- Form Scroll Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <!-- Row 1: Name -->
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Nombre de la Presentación (ej: Caja 24, Pack 6, Unidad)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,0,0,12" />

                <!-- Row 2: UOM & Barcode -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" ItemsSource="{Binding UnitsOfMeasure}" 
                              SelectedValue="{Binding UnitOfMeasureId}" 
                              SelectedValuePath="Id" 
                              DisplayMemberPath="Name" 
                              materialDesign:HintAssist.Hint="Unidad de Medida"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                              Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Código de Barras (Opcional)" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Row 3: Conversion Factor & Cost -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding ConversionFactor}" 
                             materialDesign:HintAssist.Hint="Factor de Conversión a Unidad Base" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" Text="{Binding Cost}" 
                             materialDesign:HintAssist.Hint="Costo de Presentación" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Row 4: Sale Prices (Multilevel pricing) -->
                <TextBlock Text="Lista de Precios Manual" Style="{StaticResource MaterialDesignSubtitle2TextBlock}" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding RetailPrice}" 
                             materialDesign:HintAssist.Hint="Precio Minorista (Retail)" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" Text="{Binding SemiWholesalePrice}" 
                             materialDesign:HintAssist.Hint="Precio Semi Mayorista" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,6,0" />

                    <TextBox Grid.Column="2" Text="{Binding WholesalePrice}" 
                             materialDesign:HintAssist.Hint="Precio Mayorista" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Row 6: Boolean States -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                    <CheckBox Content="Es Unidad de Medida Base" IsChecked="{Binding IsBaseUnit}" Margin="0,0,12,0" />
                    <CheckBox Content="Predeterminada para Venta" IsChecked="{Binding IsDefaultSalePresentation}" Margin="0,0,12,0" />
                    <CheckBox Content="Permitir Compra" IsChecked="{Binding AllowPurchase}" Margin="0,0,12,0" />
                    <CheckBox Content="Permitir Venta" IsChecked="{Binding AllowSale}" Margin="0,0,12,0" />
                    <CheckBox Content="Activo" IsChecked="{Binding IsActive}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold" Margin="0,0,0,8" 
                   HorizontalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Footer Actions -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,12,0" Width="100">
                    <TextBlock Text="Cancelar" />
                </Button>

                <Button Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="100">
                    <TextBlock Text="Aceptar" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
