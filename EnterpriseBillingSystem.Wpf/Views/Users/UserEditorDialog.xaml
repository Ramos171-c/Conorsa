<Window x:Class="EnterpriseBillingSystem.Wpf.Views.Users.UserEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:EnterpriseBillingSystem.Wpf.Converters"
        mc:Ignorable="d"
        Title="Detalle del Trabajador" Height="700" Width="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Editar Trabajador" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                            <Setter Property="Text" Value="Nuevo Trabajador" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel Margin="8">
                
                <!-- Sección 1: Información Personal -->
                <TextBlock Text="Información Personal" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,8,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />
                
                <!-- Nombre y Apellido -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Nombre" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Apellido" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Usuario y Correo -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Nombre de Usuario (Para Login)" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"
                             Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Correo Electrónico" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Teléfono y Cédula -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Teléfono" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding Cedula, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Cédula de Identidad" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Sección 2: Ubicación -->
                <TextBlock Text="Ubicación y Asignación" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,12,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <!-- Dirección (Domicilio) -->
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Domicilio / Dirección Completa" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,0,0,12" />

                <!-- Municipio y Ciudad -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Municipality, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Municipio" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Ciudad" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Ruta -->
                <ComboBox ItemsSource="{Binding Routes}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedRouteId, UpdateSourceTrigger=PropertyChanged}"
                          materialDesign:HintAssist.Hint="Ruta de Ventas / Distribución" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                          Margin="0,0,0,12" />

                <!-- Sección 3: Contacto de Emergencia -->
                <TextBlock Text="Contacto de Emergencia" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,12,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <!-- Nombre y Teléfono de Contacto de Emergencia -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding EmergencyContactName, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Nombre del Contacto" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Teléfono del Contacto" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Sección 4: Configuración de Seguridad -->
                <TextBlock Text="Configuración de Seguridad y Acceso" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,12,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <!-- Sucursal y Rol -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Branches}" 
                              SelectedValue="{Binding SelectedBranchId}" 
                              SelectedValuePath="Id" 
                              DisplayMemberPath="Name" 
                              materialDesign:HintAssist.Hint="Sucursal Principal"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                              Margin="0,0,6,0" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Roles}" 
                              SelectedItem="{Binding SelectedRole}" 
                              materialDesign:HintAssist.Hint="Rol de Usuario"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                              Margin="6,0,0,0" />
                </Grid>

                <!-- Contraseña (requerida para nuevo, opcional para editar) -->
                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                         materialDesign:HintAssist.Hint="Contraseña (Dejar vacío para no modificar si edita)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         Margin="0,0,0,12" />

                <!-- Sección 5: Estados -->
                <TextBlock Text="Estado" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,12,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <CheckBox Content="Trabajador Activo" IsChecked="{Binding IsEmployeeActive}" Margin="0,0,24,0" />
                    <CheckBox Content="Usuario del Sistema Activo" IsChecked="{Binding IsActive}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" 
                             Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Width="24" Height="24" HorizontalAlignment="Left" Grid.Column="0" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,12,0" Width="100">
                        <TextBlock Text="Cancelar" />
                    </Button>

                    <Button Command="{Binding SaveCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Width="100">
                        <TextBlock Text="Aceptar" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
