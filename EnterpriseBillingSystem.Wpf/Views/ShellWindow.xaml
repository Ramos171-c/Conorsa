<Window x:Class="EnterpriseBillingSystem.Wpf.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:EnterpriseBillingSystem.Wpf.Views"
        xmlns:vm="clr-namespace:EnterpriseBillingSystem.Wpf.ViewModels"
        xmlns:converters="clr-namespace:EnterpriseBillingSystem.Wpf.Converters"
        mc:Ignorable="d"
        Title="CONORZA — Escritorio Corporativo" 
        Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Domain" Width="24" Height="24" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="CONORZA — Corporativo" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Theme Toggle -->
                    <ToggleButton Style="{StaticResource MaterialDesignFlatButton}" 
                                  IsChecked="{Binding IsDarkTheme}"
                                  Command="{Binding ToggleThemeCommand}"
                                  Margin="0,0,16,0"
                                  ToolTip="Alternar Tema Claro/Oscuro">
                        <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20" Foreground="White" />
                    </ToggleButton>

                    <!-- User Profile Info -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,24,0" TextBlock.Foreground="White">
                        <TextBlock Text="{Binding Username}" FontWeight="Bold" HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding Role}" FontSize="11" Opacity="0.8" HorizontalAlignment="Right" />
                    </StackPanel>

                    <!-- Logout Button -->
                    <Button Command="{Binding LogoutCommand}" Style="{StaticResource MaterialDesignFlatButton}" Content="SALIR" Foreground="White" />
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- Main Workspace Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar Menu -->
            <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8">
                        
                        <!-- Dashboard -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToDashboardCommand}"
                                Height="48" Margin="8,4" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource MaterialDesignSeparator}" Margin="8,8" />

                        <!-- POS (Point Of Sale) -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToPosCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsPosVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashRegister" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Facturación POS" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            </StackPanel>
                        </Button>

                        <!-- Clientes -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToCustomersCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsCustomersVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroupOutline" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Clientes" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Proveedores -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToSuppliersCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsSuppliersVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TruckDeliveryOutline" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Proveedores" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Compras -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToPurchasesCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsPurchasesVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Receipt" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Compras" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Inventario (Collapsible) -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToInventoryCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsInventoryVisible, Converter={StaticResource BoolToVis}}">
                            <Grid Width="240">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="Warehouse" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Inventario" VerticalAlignment="Center" />
                                <materialDesign:PackIcon Grid.Column="2" Kind="ChevronDown" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInventorySubMenuOpen}" Value="True">
                                                    <Setter Property="Kind" Value="ChevronUp" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </Grid>
                        </Button>

                        <StackPanel Visibility="{Binding IsInventorySubMenuOpen, Converter={StaticResource BoolToVis}}" Margin="24,0,0,0">
                            <!-- Dashboard -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryDashboardCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Productos -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToProductsCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PackageVariantClosed" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Productos" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Existencias -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryStockCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ListBoxOutline" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Existencias" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Movimientos (Kardex) -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryMovementsCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="History" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Movimientos" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Auditoría de Precios -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryAuditsCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldCheckOutline" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Auditoría" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Ajustes -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryAdjustmentsCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Visibility="{Binding IsInventoryAdjustVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Tune" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Ajustes" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Transferencias -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryTransfersCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Visibility="{Binding IsInventoryTransferVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowLeftRight" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Transferencias" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Reportes -->
                            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                    Command="{Binding NavigateToInventoryReportsCommand}"
                                    Height="36" Margin="4,1" HorizontalContentAlignment="Left"
                                    materialDesign:ButtonAssist.CornerRadius="6"
                                    Visibility="{Binding IsInventoryReportVisible, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Reportes" FontSize="13" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Ventas -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToSalesCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsSalesVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CartOutline" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Ventas" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Pedidos Móviles -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToMobileOrdersCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsMobileOrdersVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CellphoneText" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Pedidos Móviles" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>


                        <!-- Trabajadores -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToUsersCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsUsersVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountTieOutline" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Trabajadores" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource MaterialDesignSeparator}" Margin="8,8" />

                        <!-- Administración -->
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding NavigateToAdministrationCommand}"
                                Height="48" Margin="8,2" HorizontalContentAlignment="Left"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Visibility="{Binding IsAdministrationVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CogOutline" Width="20" Height="20" Margin="0,0,16,0" VerticalAlignment="Center" />
                                <TextBlock Text="Administración" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Main Content Area -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="8" />
        </Grid>
        
        <!-- Global Snackbar Notifications -->
        <materialDesign:Snackbar Grid.Row="1" Grid.ColumnSpan="2" x:Name="MainSnackbar" MessageQueue="{materialDesign:MessageQueue}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24" />
    </Grid>
</Window>
