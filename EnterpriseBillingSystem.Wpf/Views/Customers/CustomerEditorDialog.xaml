<Window x:Class="EnterpriseBillingSystem.Wpf.Views.Customers.CustomerEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:EnterpriseBillingSystem.Wpf.Converters"
        mc:Ignorable="d"
        Title="Detalle del Cliente" Height="700" Width="750"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:BooleanToVisibilityConverter x:Key="InverseBoolToVis" Inverse="True" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="Text" Value="Editar Cliente" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                            <Setter Property="Text" Value="Nuevo Cliente" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Scrollable Form Container -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <!-- Información General -->
                <TextBlock Text="Información General" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,4" />
                <Separator Margin="0,0,0,12" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />

                <!-- Grid for Name & Legal Name -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" 
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Nombre del Cliente (Comercial) *" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" 
                             Text="{Binding LegalName, UpdateSourceTrigger=PropertyChanged}" 
                             materialDesign:HintAssist.Hint="Razón Social / Nombre Legal" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                             Margin="6,0,0,0" />
                </Grid>

                <!-- Grid for Route and Status -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" 
                              ItemsSource="{Binding Routes}" 
                              SelectedValue="{Binding SelectedRouteId}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              materialDesign:HintAssist.Hint="Ruta del Cliente (Opcional)"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,6,0" />

                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding CustomerStatuses}" 
                              SelectedItem="{Binding SelectedStatus}"
                              materialDesign:HintAssist.Hint="Estado Cliente *"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="6,0,0,0" />
                </Grid>

                <!-- Direcciones -->
                <DockPanel Margin="0,16,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="Direcciones de Despacho" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Command="{Binding AddAddressCommand}" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="Agregar Dirección" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                </DockPanel>
                <Separator Margin="0,0,0,8" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />
                <DataGrid ItemsSource="{Binding Addresses}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Height="130" MinHeight="100" Margin="0,0,0,16">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Calle / Dirección *" Binding="{Binding AddressLine1, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                        <DataGridTextColumn Header="Detalles" Binding="{Binding AddressLine2, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        <DataGridTextColumn Header="Ciudad *" Binding="{Binding City, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridTextColumn Header="Dpto / Estado" Binding="{Binding State, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridTemplateColumn Header="Tipo" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AddressType}" VerticalAlignment="Center" Margin="8,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.AddressTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding AddressType, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridCheckBoxColumn Header="Predet." Binding="{Binding IsDefault, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveAddressCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26" Padding="0">
                                        <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Foreground="#C62828" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Teléfonos y Correos -->
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Phones -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="Teléfonos" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" Command="{Binding AddPhoneCommand}" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Right" Padding="0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Agregar" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <Separator Margin="0,0,0,8" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />
                        <DataGrid ItemsSource="{Binding Phones}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Height="110" MinHeight="80">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Número *" Binding="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTemplateColumn Header="Tipo" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PhoneType}" VerticalAlignment="Center" Margin="8,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.PhoneTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding PhoneType, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridCheckBoxColumn Header="Predet." Binding="{Binding IsDefault, UpdateSourceTrigger=PropertyChanged}" Width="65" />
                                <DataGridTemplateColumn Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemovePhoneCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24" Padding="0">
                                                <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Foreground="#C62828" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Right: Emails -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="Correos" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" Command="{Binding AddEmailCommand}" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Right" Padding="0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Agregar" VerticalAlignment="Center" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <Separator Margin="0,0,0,8" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />
                        <DataGrid ItemsSource="{Binding Emails}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Height="110" MinHeight="80">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Email *" Binding="{Binding EmailAddress, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTemplateColumn Header="Tipo" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EmailType}" VerticalAlignment="Center" Margin="8,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.EmailTypes, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding EmailType, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                                <DataGridCheckBoxColumn Header="Predet." Binding="{Binding IsDefault, UpdateSourceTrigger=PropertyChanged}" Width="65" />
                                <DataGridTemplateColumn Width="45">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemoveEmailCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24" Padding="0">
                                                <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Foreground="#C62828" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Grid>

                <!-- Contactos -->
                <DockPanel Margin="0,8,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="Personas de Contacto" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Command="{Binding AddContactCommand}" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="Agregar Contacto" VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                    </Button>
                </DockPanel>
                <Separator Margin="0,0,0,8" Background="{DynamicResource PrimaryHueLightBrush}" Height="1.5" />
                <DataGrid ItemsSource="{Binding Contacts}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Height="120" MinHeight="80">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre *" Binding="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridTextColumn Header="Apellido" Binding="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridTextColumn Header="Cargo" Binding="{Binding JobTitle, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        <DataGridTextColumn Header="Teléfono" Binding="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        <DataGridTextColumn Header="Email" Binding="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                        <DataGridTextColumn Header="Notas" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        <DataGridCheckBoxColumn Header="Predet." Binding="{Binding IsDefault, UpdateSourceTrigger=PropertyChanged}" Width="65" />
                        <DataGridTemplateColumn Width="45">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveContactCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24" Padding="0">
                                        <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Foreground="#C62828" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}" 
                    Content="Cancelar" 
                    Click="CancelButton_Click" 
                    Margin="0,0,8,0" 
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}" />

            <Button Command="{Binding SaveCommand}" 
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Width="120"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}">
                <Grid>
                    <TextBlock Text="Guardar" Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVis}}" />
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Width="20" Height="20" Foreground="White" Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Button>
        </StackPanel>
    </Grid>
</Window>
