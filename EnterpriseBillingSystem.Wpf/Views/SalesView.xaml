<UserControl x:Class="EnterpriseBillingSystem.Wpf.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:EnterpriseBillingSystem.Wpf.Views"
             xmlns:vm="clr-namespace:EnterpriseBillingSystem.Wpf.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:SalesViewModel}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 0. Header & Filters -->
            <RowDefinition Height="Auto" />
            <!-- 1. KPI Summary Cards -->
            <RowDefinition Height="Auto" />
            <!-- 2. Main Content Tabs -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Header & Filters -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="16" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignCardBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title & Subtitle -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Reporte y Análisis de Ventas" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text="Consulte el desempeño financiero agrupado por cliente, zona o rango de fechas" FontSize="12" Opacity="0.7" Margin="0,2,0,0" />
                </StackPanel>

                <!-- Filter Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Date Range Start -->
                    <DatePicker Width="130" Margin="0,0,12,0"
                                materialDesign:HintAssist.Hint="Fecha Inicial"
                                SelectedDate="{Binding StartDate, Mode=TwoWay}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                    <!-- Date Range End -->
                    <DatePicker Width="130" Margin="0,0,12,0"
                                materialDesign:HintAssist.Hint="Fecha Final"
                                SelectedDate="{Binding EndDate, Mode=TwoWay}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                    <!-- Status Filter -->
                    <ComboBox Width="130" Margin="0,0,12,0"
                              materialDesign:HintAssist.Hint="Estado"
                              ItemsSource="{Binding Statuses}"
                              SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                    <!-- Search Input -->
                    <TextBox Width="200" Margin="0,0,12,0"
                             materialDesign:HintAssist.Hint="Buscar cliente o zona..."
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoadSalesDataCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Refresh Button -->
                    <Button Command="{Binding LoadSalesDataCommand}" 
                            Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                            ToolTip="Refrescar Datos" Width="36" Height="36" Padding="0">
                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Row 1: KPI Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Sales -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="16" UniformCornerRadius="12" Background="#4A148C">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VENTAS TOTALES" FontSize="11" FontWeight="Bold" Foreground="#E1BEE7" />
                        <TextBlock Text="{Binding TotalSales, StringFormat=C2}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,8,0,0" />
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="1" Kind="CurrencyUsd" Width="32" Height="32" Foreground="#E1BEE7" Opacity="0.5" VerticalAlignment="Center" />
                </Grid>
            </materialDesign:Card>

            <!-- Card 2: Orders Count -->
            <materialDesign:Card Grid.Column="1" Margin="8,0,8,0" Padding="16" UniformCornerRadius="12" Background="#1976D2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CANTIDAD PEDIDOS" FontSize="11" FontWeight="Bold" Foreground="#BBDEFB" />
                        <TextBlock Text="{Binding TotalOrdersCount}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,8,0,0" />
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="1" Kind="TrendingUp" Width="32" Height="32" Foreground="#BBDEFB" Opacity="0.5" VerticalAlignment="Center" />
                </Grid>
            </materialDesign:Card>

            <!-- Card 3: Average Ticket -->
            <materialDesign:Card Grid.Column="2" Margin="8,0,8,0" Padding="16" UniformCornerRadius="12" Background="#00796B">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TICKET PROMEDIO" FontSize="11" FontWeight="Bold" Foreground="#B2DFDB" />
                        <TextBlock Text="{Binding AverageTicket, StringFormat=C2}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,8,0,0" />
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="1" Kind="CardAccountDetailsOutline" Width="32" Height="32" Foreground="#B2DFDB" Opacity="0.5" VerticalAlignment="Center" />
                </Grid>
            </materialDesign:Card>

            <!-- Card 4: Top Product -->
            <materialDesign:Card Grid.Column="3" Margin="8,0,0,0" Padding="16" UniformCornerRadius="12" Background="#E65100">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRODUCTO ESTRELLA" FontSize="11" FontWeight="Bold" Foreground="#FFE0B2" />
                        <TextBlock Text="{Binding TopProduct}" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,12,0,0" TextTrimming="CharacterEllipsis" MaxWidth="160" />
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="1" Kind="Crown" Width="32" Height="32" Foreground="#FFE0B2" Opacity="0.5" VerticalAlignment="Center" />
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Row 2: TabContent -->
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="8" Background="{DynamicResource MaterialDesignCardBackground}">
            <TabControl Style="{StaticResource MaterialDesignNavigationRailTabControl}" materialDesign:ColorZoneAssist.Mode="PrimaryMid">
                
                <!-- Tab 1: General Product Ranking -->
                <TabItem Header="Resumen de Productos" Width="180" Height="48">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Top 5 Productos más Vendidos (Por Monto Neto)" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource MaterialDesignBody}" />
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TopSellingProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="{Binding ProductCode}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                                                <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource MaterialDesignBody}" />
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TotalQuantity, StringFormat=N0}" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                                    <TextBlock Text="{Binding UnitOfMeasure}" FontSize="12" Margin="4,0,0,0" Opacity="0.7" VerticalAlignment="Bottom" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding TotalNetAmount, StringFormat=C2}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#2E7D32" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Sales By Client -->
                <TabItem Header="Ventas por Cliente" Width="180" Height="48">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Volumen de Facturación por Cliente" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource MaterialDesignBody}" />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SalesByClient}" AutoGenerateColumns="False" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Código" Binding="{Binding CustomerCode}" Width="120" />
                                <DataGridTextColumn Header="Nombre del Cliente" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="Zona / Ruta" Binding="{Binding ZoneName}" Width="180" />
                                <DataGridTextColumn Header="Cant. Pedidos" Binding="{Binding OrdersCount}" Width="120" ElementStyle="{StaticResource CenterAlignedColumnStyle}" />
                                <DataGridTextColumn Header="Total Ventas" Binding="{Binding TotalSales, StringFormat=C2}" Width="150" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 3: Sales By Zone -->
                <TabItem Header="Ventas por Zona" Width="180" Height="48">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Análisis de Ventas Agrupadas por Zona (Ruta)" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource MaterialDesignBody}" />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding SalesByZone}" AutoGenerateColumns="False" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Zona / Ruta" Binding="{Binding ZoneName}" Width="*" />
                                <DataGridTextColumn Header="Clientes en Zona" Binding="{Binding ClientsCount}" Width="150" ElementStyle="{StaticResource CenterAlignedColumnStyle}" />
                                <DataGridTextColumn Header="Cant. Pedidos" Binding="{Binding OrdersCount}" Width="150" ElementStyle="{StaticResource CenterAlignedColumnStyle}" />
                                <DataGridTextColumn Header="Total Ventas" Binding="{Binding TotalSales, StringFormat=C2}" Width="200" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 4: Detailed Invoices Log -->
                <TabItem Header="Listado de Ventas" Width="180" Height="48">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Bitácora de Pedidos / Facturas en el Periodo" FontSize="15" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource MaterialDesignBody}" />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredOrders}" AutoGenerateColumns="False" IsReadOnly="True" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nº Pedido" Binding="{Binding OrderNumber}" Width="120" />
                                <DataGridTextColumn Header="Fecha" Binding="{Binding OrderDate, StringFormat=g}" Width="150" />
                                <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C2}" Width="120" ElementStyle="{StaticResource RightAlignedColumnStyle}" />
                                <DataGridTemplateColumn Header="Estado" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Borrador">
                                                                <Setter Property="Background" Value="#F5F5F5" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Confirmado">
                                                                <Setter Property="Background" Value="#E3F2FD" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Facturado">
                                                                <Setter Property="Background" Value="#E8F5E9" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Anulado">
                                                                <Setter Property="Background" Value="#FFEBEE" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Borrador">
                                                                    <Setter Property="Foreground" Value="#757575" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Confirmado">
                                                                    <Setter Property="Foreground" Value="#1976D2" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Facturado">
                                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Anulado">
                                                                    <Setter Property="Foreground" Value="#C62828" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Usuario" Binding="{Binding CreatedBy}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </materialDesign:Card>

        <!-- Loading Mask -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Background="#80000000" 
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
              Focusable="True" IsHitTestVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" 
                             Value="0" IsIndeterminate="True" 
                             Width="64" Height="64" Foreground="White" />
                <TextBlock Text="Cargando y procesando ventas..." Margin="0,16,0,0" Foreground="White" FontSize="16" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
